# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://memorywiki:memorywiki@postgres:5432/memorywiki
DATABASE_URL_SYNC=postgresql+psycopg2://memorywiki:memorywiki@postgres:5432/memorywiki

# ── Redis / Celery ────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── MinIO (S3-compatible) ─────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=memories
S3_REGION=us-east-1

# ── LLM ───────────────────────────────────────────────────────
LLM_API_KEY=your-api-key-here
LLM_MODEL=mistral-small-latest
LLM_BASE_URL=https://api.mistral.ai/v1

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
